{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "player.schema.json",
  "title": "Player Data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "players"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "players": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/player"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zhTw"
      ],
      "properties": {
        "zhTw": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string"
        }
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mechanics",
        "laning",
        "teamFight",
        "mapAwareness",
        "championPool",
        "mental"
      ],
      "properties": {
        "mechanics": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "laning": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "teamFight": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "mapAwareness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "championPool": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "mental": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "salary",
        "monthsRemaining"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "freeAgent",
            "contracted",
            "retired"
          ]
        },
        "teamId": {
          "$ref": "#/$defs/id"
        },
        "salary": {
          "type": "integer",
          "minimum": 0
        },
        "monthsRemaining": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "player": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "age",
        "mainLane",
        "role",
        "heroPool",
        "attributes",
        "contract",
        "reputation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "age": {
          "type": "integer",
          "minimum": 15,
          "maximum": 45
        },
        "mainLane": {
          "type": "string",
          "enum": [
            "top",
            "mid",
            "bottom",
            "jungle",
            "support"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "tank",
            "fighter",
            "assassin",
            "mage",
            "marksman",
            "support"
          ]
        },
        "heroPool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "attributes": {
          "$ref": "#/$defs/attributes"
        },
        "contract": {
          "$ref": "#/$defs/contract"
        },
        "reputation": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true,
          "default": []
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
