{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "league.schema.json",
  "title": "League Data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "leagues"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "leagues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/league"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zhTw"
      ],
      "properties": {
        "zhTw": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string"
        }
      }
    },
    "scheduleRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roundRobinRounds",
        "bestOf",
        "playoffTeamCount"
      ],
      "properties": {
        "roundRobinRounds": {
          "type": "integer",
          "minimum": 1
        },
        "bestOf": {
          "type": "integer",
          "enum": [
            1,
            3,
            5
          ]
        },
        "playoffTeamCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "league": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "region",
        "season",
        "teamIds",
        "format",
        "scheduleRules",
        "worldsQualificationSlots"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "region": {
          "type": "string",
          "enum": [
            "tw",
            "kr",
            "cn",
            "jp",
            "na",
            "eu",
            "sea",
            "world"
          ]
        },
        "season": {
          "type": "integer",
          "minimum": 1
        },
        "teamIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "format": {
          "type": "string",
          "enum": [
            "singleRoundRobin",
            "doubleRoundRobin",
            "leagueWithPlayoffs"
          ]
        },
        "scheduleRules": {
          "$ref": "#/$defs/scheduleRules"
        },
        "worldsQualificationSlots": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
