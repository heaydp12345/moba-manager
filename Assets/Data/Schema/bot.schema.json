{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bot.schema.json",
  "title": "Bot AI Data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bots"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "bots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bot"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zhTw"
      ],
      "properties": {
        "zhTw": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string"
        }
      }
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "behaviorWeights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lastHit",
        "laning",
        "retreat",
        "teamFight",
        "itemBuild",
        "pushTower",
        "jungle",
        "objectiveControl"
      ],
      "properties": {
        "lastHit": {
          "$ref": "#/$defs/weight"
        },
        "laning": {
          "$ref": "#/$defs/weight"
        },
        "retreat": {
          "$ref": "#/$defs/weight"
        },
        "teamFight": {
          "$ref": "#/$defs/weight"
        },
        "itemBuild": {
          "$ref": "#/$defs/weight"
        },
        "pushTower": {
          "$ref": "#/$defs/weight"
        },
        "jungle": {
          "$ref": "#/$defs/weight"
        },
        "objectiveControl": {
          "$ref": "#/$defs/weight"
        }
      }
    },
    "decisionThresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retreatHealthRatio",
        "allInHealthRatio",
        "groupUpAllyRatio",
        "objectiveContestRatio"
      ],
      "properties": {
        "retreatHealthRatio": {
          "$ref": "#/$defs/threshold"
        },
        "allInHealthRatio": {
          "$ref": "#/$defs/threshold"
        },
        "groupUpAllyRatio": {
          "$ref": "#/$defs/threshold"
        },
        "objectiveContestRatio": {
          "$ref": "#/$defs/threshold"
        }
      }
    },
    "lanePreference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primaryLane",
        "secondaryLanes"
      ],
      "properties": {
        "primaryLane": {
          "type": "string",
          "enum": [
            "top",
            "mid",
            "bottom",
            "jungle",
            "support"
          ]
        },
        "secondaryLanes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "top",
              "mid",
              "bottom",
              "jungle",
              "support"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "itemBuildPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preferredItemIds"
      ],
      "properties": {
        "preferredItemIds": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "fallbackItemIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "bot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "difficulty",
        "role",
        "heroPool",
        "lanePreference",
        "behaviorWeights",
        "decisionThresholds",
        "itemBuildPlan"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "normal",
            "hard",
            "expert"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "tank",
            "fighter",
            "assassin",
            "mage",
            "marksman",
            "support"
          ]
        },
        "heroPool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "lanePreference": {
          "$ref": "#/$defs/lanePreference"
        },
        "behaviorWeights": {
          "$ref": "#/$defs/behaviorWeights"
        },
        "decisionThresholds": {
          "$ref": "#/$defs/decisionThresholds"
        },
        "itemBuildPlan": {
          "$ref": "#/$defs/itemBuildPlan"
        },
        "seedPolicy": {
          "type": "string",
          "enum": [
            "matchSeed",
            "fixedSeed",
            "none"
          ],
          "default": "matchSeed"
        },
        "fixedSeed": {
          "type": "integer",
          "minimum": 0
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true,
          "default": []
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "seedPolicy": {
                "const": "fixedSeed"
              }
            }
          },
          "then": {
            "required": [
              "fixedSeed"
            ]
          }
        }
      ]
    }
  }
}
