{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "map.schema.json",
  "title": "Map Data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "maps"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "maps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/map"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zhTw"
      ],
      "properties": {
        "zhTw": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string"
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "nexus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "team",
        "position",
        "maxHealth"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "team": {
          "type": "string",
          "enum": [
            "blue",
            "red"
          ]
        },
        "position": {
          "$ref": "#/$defs/point"
        },
        "maxHealth": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "pathNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "position"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "position": {
          "$ref": "#/$defs/point"
        }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "laneType",
        "pathNodes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "laneType": {
          "type": "string",
          "enum": [
            "top",
            "mid",
            "bottom"
          ]
        },
        "pathNodes": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/pathNode"
          }
        }
      }
    },
    "tower": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "team",
        "laneType",
        "position",
        "attackRange",
        "attackDamage",
        "maxHealth"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "team": {
          "type": "string",
          "enum": [
            "blue",
            "red"
          ]
        },
        "laneType": {
          "type": "string",
          "enum": [
            "top",
            "mid",
            "bottom"
          ]
        },
        "position": {
          "$ref": "#/$defs/point"
        },
        "attackRange": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "attackDamage": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "maxHealth": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "jungleZone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "side",
        "center",
        "radius"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "side": {
          "type": "string",
          "enum": [
            "blue",
            "red",
            "neutral"
          ]
        },
        "center": {
          "$ref": "#/$defs/point"
        },
        "radius": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "campIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "minionWaveRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "laneType",
        "bluePathNodeIds",
        "redPathNodeIds"
      ],
      "properties": {
        "laneType": {
          "type": "string",
          "enum": [
            "top",
            "mid",
            "bottom"
          ]
        },
        "bluePathNodeIds": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "redPathNodeIds": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "visionSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaultVisionRadius": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "mapType",
        "size",
        "nexuses",
        "lanes",
        "towers",
        "jungleZones",
        "minionWaveRoutes",
        "vision"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "mapType": {
          "type": "string",
          "enum": [
            "moba"
          ]
        },
        "size": {
          "$ref": "#/$defs/size"
        },
        "nexuses": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/nexus"
          }
        },
        "lanes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/lane"
          }
        },
        "towers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/tower"
          }
        },
        "jungleZones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jungleZone"
          },
          "default": []
        },
        "minionWaveRoutes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/minionWaveRoute"
          }
        },
        "vision": {
          "$ref": "#/$defs/visionSettings"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
